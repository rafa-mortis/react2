{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "settings": {
        "chromeFlags": "--no-sandbox --headless"
      },
      "url": [
        "http://localhost:3000"
      ]
    },
    "assert": {
      "assertions": {
        "categories:performance": ["off"],
        "categories:accessibility": ["off"],
        "categories:best-practices": ["off"],
        "categories:seo": ["off"]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
